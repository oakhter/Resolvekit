# Required. Provider. Accepted: openai, gemini, or mock. mock is no-key preview only.
ACTIVE_PROVIDER=openai

# Optional. Keeps demo data paths enabled for sandbox runs.
DEMO_MODE=true

# Required if ACTIVE_PROVIDER=openai. Used for draft generation.
OPENAI_API_KEY=

# Required if ACTIVE_PROVIDER=gemini. Used for draft generation.
GEMINI_API_KEY=

# No provider API key required when ACTIVE_PROVIDER=mock. Drafts are canned and labeled MOCK PREVIEW.

# Required. Viewer/API token for ticket workspace requests.
API_KEY=change-me

# Required. Configurator/admin token; must differ from API_KEY.
CONFIGURATOR_API_KEY=change-me-configurator

# Required. Trace viewer token; must be non-placeholder.
VIEWER_TOKEN=replace-with-random-viewer-token

# Required. Admin/configurator elevated token; must differ from viewer keys.
CONFIGURATOR_ADMIN_TOKEN=replace-with-random-admin-token

# Required. Local Postgres with pgvector.
DATABASE_URL=postgresql://resolvekit:resolvekit@localhost:5432/resolvekit

# Required. Vector/knowledge schema name.
KNOWLEDGE_SCHEMA=knowledge

# Required. Operational schema name.
OPS_SCHEMA=ops

# Optional. Disable in constrained local environments; Docker defaults false.
WARM_LOCAL_MODELS=false

# Optional. Only true for local demos when API key prefill is desired.
CONFIGURATOR_PREFILL_API_KEY=false

# Optional. Source preview size cap in bytes.
CONFIGURATOR_SOURCE_PREVIEW_MAX_BYTES=26214400

# Required for browser UI calls.
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
